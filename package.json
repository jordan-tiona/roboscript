{
  "name": "roboscript",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev:all": "concurrently -n client,server -c cyan,yellow \"pnpm dev\" \"pnpm dev:server\"",
    "build": "pnpm --filter engine build && pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": { "node": ">=24", "pnpm": ">=10" },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
